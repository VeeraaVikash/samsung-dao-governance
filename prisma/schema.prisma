generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users & Auth ──

enum UserRole {
  ADMIN
  COUNCIL
  MEMBER
}

enum MemberType {
  PROPOSER
  DELEGATE
}

model User {
  id            String      @id @default(cuid())
  employeeId    String      @unique               // SEC-2024-00421
  email         String      @unique
  name          String
  password      String                             // bcrypt hash
  department    String      @default("R&D Division")
  role          UserRole    @default(MEMBER)
  memberType    MemberType  @default(PROPOSER)
  kycVerified   Boolean     @default(false)
  active        Boolean     @default(true)

  // Hedera wallet binding
  hederaAccountId  String?  @unique
  walletBound      Boolean  @default(false)
  walletProvider   String?                         // hashpack | walletconnect | blade
  walletBoundAt    DateTime?

  // Reputation
  reputationScore  Int      @default(0)
  spuBalance       Int      @default(0)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  proposals     Proposal[]  @relation("ProposalAuthor")
  votes         Vote[]
  delegationsGiven    Delegation[] @relation("Delegator")
  delegationsReceived Delegation[] @relation("Delegate")
  multisigSignatures  MultisigSignature[]
  sessions      Session[]

  @@map("users")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ── Governance ──

model GovernanceRule {
  id                 String   @id @default(cuid())
  period             Int      @default(1)          // governance period number
  quorumThreshold    Int      @default(51)         // percentage
  votingWindowHours  Int      @default(72)
  minReputationScore Int      @default(100)
  delegationLimit    Int      @default(5)
  executionDelayHours Int     @default(48)
  timelockWindowHours Int     @default(48)
  multisigRequired   Int      @default(3)
  multisigTotal      Int      @default(5)
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("governance_rules")
}

// ── Proposals ──

enum ProposalStatus {
  DRAFT
  PENDING
  APPROVED
  EXECUTING
  COMPLETED
  REJECTED
}

model Proposal {
  id          String         @id @default(cuid())
  number      Int            @unique @default(autoincrement())
  title       String
  description String
  authorId    String
  status      ProposalStatus @default(DRAFT)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  author      User           @relation("ProposalAuthor", fields: [authorId], references: [id])

  @@map("proposals")
}

// ── Elections ──

enum ElectionStatus {
  DRAFT
  SCHEDULED
  LIVE
  CLOSED
  FINALIZED
}

enum ElectionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  RANKED
}

model Election {
  id                    String         @id @default(cuid())
  title                 String
  status                ElectionStatus @default(DRAFT)
  electionType          ElectionType   @default(SINGLE_CHOICE)
  startDate             DateTime
  endDate               DateTime
  eligibleMemberCount   Int            @default(0)
  requireReputation     Boolean        @default(true)
  allowDelegation       Boolean        @default(true)
  snapshotEligibility   Boolean        @default(false)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  candidates            Candidate[]
  votes                 Vote[]

  @@map("elections")
}

model Candidate {
  id           String   @id @default(cuid())
  electionId   String
  name         String
  department   String
  voteCount    Int      @default(0)

  election     Election @relation(fields: [electionId], references: [id], onDelete: Cascade)
  votes        Vote[]

  @@map("candidates")
}

model Vote {
  id           String   @id @default(cuid())
  electionId   String
  candidateId  String
  userId       String
  createdAt    DateTime @default(now())

  election     Election  @relation(fields: [electionId], references: [id])
  candidate    Candidate @relation(fields: [candidateId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@unique([electionId, userId])
  @@map("votes")
}

// ── Delegation ──

model Delegation {
  id           String   @id @default(cuid())
  delegatorId  String
  delegateId   String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())

  delegator    User     @relation("Delegator", fields: [delegatorId], references: [id])
  delegate     User     @relation("Delegate", fields: [delegateId], references: [id])

  @@unique([delegatorId, delegateId])
  @@map("delegations")
}

// ── Events (Lottery & Giveaway) ──

enum EventType {
  LOTTERY
  GIVEAWAY
}

enum EventStatus {
  UPCOMING
  ACTIVE
  CLOSED
}

model GovernanceEvent {
  id          String      @id @default(cuid())
  type        EventType
  title       String
  description String      @default("")
  status      EventStatus @default(UPCOMING)
  prize       String      @default("")
  drawDate    DateTime?
  closesAt    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  entries     EventEntry[]

  @@map("governance_events")
}

model EventEntry {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime @default(now())

  event     GovernanceEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_entries")
}

// ── Multisig ──

enum MultisigActionStatus {
  PENDING
  EXECUTED
  EXPIRED
}

model MultisigAction {
  id              String              @id @default(cuid())
  description     String
  proposalNumber  Int?
  requiredSigs    Int                 @default(3)
  totalSigners    Int                 @default(5)
  status          MultisigActionStatus @default(PENDING)
  createdAt       DateTime            @default(now())
  expiresAt       DateTime

  signatures      MultisigSignature[]

  @@map("multisig_actions")
}

model MultisigSignature {
  id        String   @id @default(cuid())
  actionId  String
  userId    String
  signedAt  DateTime @default(now())

  action    MultisigAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id])

  @@unique([actionId, userId])
  @@map("multisig_signatures")
}

// ── Contract Event Log (simulated) ──

model ContractLog {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  contractName String
  eventType    String
  details      String
  txHash       String?

  @@map("contract_logs")
}
